# Локально или в панели Render → Environment
# Для облачной БД (Render PostgreSQL) достаточно DATABASE_URL:
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Либо отдельные поля (если без DATABASE_URL):
# DB_HOST=
# DB_PORT=5432
# DB_NAME=
# DB_USER=
# DB_PASSWORD=

# SSL для облачных БД (по умолчанию включён при DATABASE_URL). Отключить: DB_SSL=false
# DB_SSL=

PORT=4000
ADMIN_PASSWORD=
ADMIN_COOKIE_SECRET=
